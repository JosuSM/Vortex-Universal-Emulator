<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage for ROMs and saves -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Vibration for haptic feedback on controls -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Keep screen on during emulation -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Gamepad support -->
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <!-- OpenGL ES 3.2 for GPU rendering -->
    <uses-feature android:glEsVersion="0x00030002" android:required="false" />

    <!-- Vulkan support -->
    <uses-feature android:name="android.hardware.vulkan.level" android:required="false" />

    <application
        android:name=".VortexApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vortex.Splash"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="userLandscape"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ROM file associations -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>

        <!-- Emulation service for background audio -->
        <service
            android:name=".service.EmulationService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

    </application>

</manifest>
