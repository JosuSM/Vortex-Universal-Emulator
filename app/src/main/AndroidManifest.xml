<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage for ROMs and saves -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Vibration for haptic feedback on controls -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Keep screen on during emulation -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Internet for downloading libretro cores -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Install standalone emulator APKs downloaded from GitHub -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Network state for offline detection -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Query standalone emulator packages (Android 11+ package visibility) -->
    <queries>
        <!-- PSP -->
        <package android:name="org.ppsspp.ppssppgold" />
        <package android:name="org.ppsspp.ppsspp" />
        <!-- N64 -->
        <package android:name="org.mupen64plusae.v3.fzurita" />
        <package android:name="org.mupen64plusae.v3.fzurita.pro" />
        <package android:name="paulscode.android.mupen64plus.free" />
        <!-- GCN/Wii -->
        <package android:name="org.dolphinemu.dolphinemu" />
        <package android:name="org.mm.jr" />
        <!-- 3DS -->
        <package android:name="org.citra.emu" />
        <package android:name="io.github.lime3ds.android" />
        <!-- Dreamcast -->
        <package android:name="com.flycast.emulator" />
        <package android:name="io.recompiled.redream" />
        <package android:name="com.reicast.emulator" />
        <!-- PS2 -->
        <package android:name="xyz.aethersx2.android" />
        <package android:name="xyz.nethersx2.android" />
        <!-- PSX -->
        <package android:name="com.github.stenzek.duckstation" />
        <!-- Saturn -->
        <package android:name="org.uoyabause.urern" />
        <!-- NDS -->
        <package android:name="com.dsemu.drastic" />
        <package android:name="me.magnum.melonds" />
        <!-- PS Vita -->
        <package android:name="org.nicholasopuni31.vita3k" />
        <!-- Multi-System -->
        <package android:name="com.nicholasopuni31.lemuroid" />
        <package android:name="com.retroarch" />
        <package android:name="com.retroarch.aarch64" />
        <!-- SNES -->
        <package android:name="com.explusalpha.Snes9xPlus" />
        <!-- GBA -->
        <package android:name="io.mgba.mgba" />
        <!-- Play Store (for install intents) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="market" />
        </intent>
    </queries>

    <!-- Gamepad support -->
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <!-- OpenGL ES 3.2 for GPU rendering -->
    <uses-feature android:glEsVersion="0x00030002" android:required="false" />

    <!-- Vulkan support -->
    <uses-feature android:name="android.hardware.vulkan.level" android:required="false" />

    <application
        android:name=".VortexApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vortex.Splash"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        android:usesCleartextTraffic="true"
        android:appCategory="game"
        android:isGame="true"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:screenOrientation="fullUser"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ROM file associations -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>

        <!-- Emulation service for background audio -->
        <service
            android:name=".service.EmulationService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

        <!-- FileProvider for sharing ROM files with standalone emulators -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
